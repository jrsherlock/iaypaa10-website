# Copy this file to .env.local and fill in the values.
# .env.local is gitignored.

# Loops (https://loops.so) API key — used by /api/subscribe to add contacts
# and fire the 'signedUp' event. Get this from Loops → Settings → API.
LOOPS_API_KEY=

# Transactional id of the welcome email /api/subscribe sends on signup.
# One-time: in Loops create a Transactional email (body = docs/welcome-email.html),
# copy its transactionalId here and into Vercel. Unset = welcome email skipped
# (signup still works). See docs/welcome-email.md.
LOOPS_TRANSACTIONAL_WELCOME_ID=
